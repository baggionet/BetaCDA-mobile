# ============================================================
# AttendanceSaaS Mobile — Variables de entorno
# ============================================================
#
# Expo expone las variables que empiezan con EXPO_PUBLIC_
# automáticamente en process.env — no necesitas librerías
# adicionales como react-native-dotenv.
#
# IMPORTANTE: la URL correcta depende de DÓNDE estés probando:

# ── Simulador de iOS (comparte red con tu Mac) ──────────────
# Puedes usar tu dominio de Herd directamente:
EXPO_PUBLIC_API_URL=http://betacda.test/api/v1

# ── Emulador de Android Studio ──────────────────────────────
# localhost NO funciona. Usa 10.0.2.2 (alias especial del emulador
# que apunta a la máquina host). Pero como usas Herd con dominio
# .test, necesitas en su lugar la IP local de tu Mac (ver abajo).

# ── Dispositivo físico (iOS o Android) ──────────────────────
# Necesitas la IP local de tu Mac en la red WiFi.
# Obtenla con: ipconfig getifaddr en0   (Mac, WiFi)
# Ejemplo:
# EXPO_PUBLIC_API_URL=http://192.168.1.50/api/v1
#
# Y en Herd, asegúrate que el sitio acepte conexiones desde
# esa IP (Herd suele permitirlo por defecto en red local).
